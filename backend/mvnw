#!/usr/bin/env sh
set -eu

BASE_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
DIST_VERSION=3.9.9
DIST_ARCHIVE="apache-maven-${DIST_VERSION}-bin.zip"
DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${DIST_VERSION}/${DIST_ARCHIVE}"
DIST_DIR="${HOME}/.m2/wrapper/dists/apache-maven-${DIST_VERSION}-bin"
MAVEN_HOME="${DIST_DIR}/apache-maven-${DIST_VERSION}"
MVN_CMD="${MAVEN_HOME}/bin/mvn"

if [ ! -x "${MVN_CMD}" ]; then
  mkdir -p "${DIST_DIR}"

  if [ ! -f "${DIST_DIR}/${DIST_ARCHIVE}" ]; then
    echo "Downloading Maven ${DIST_VERSION}..."
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "${DIST_URL}" -o "${DIST_DIR}/${DIST_ARCHIVE}"
    elif command -v wget >/dev/null 2>&1; then
      wget -q "${DIST_URL}" -O "${DIST_DIR}/${DIST_ARCHIVE}"
    else
      echo "curl or wget is required to download Maven." >&2
      exit 1
    fi
  fi

  if [ ! -x "${MVN_CMD}" ]; then
    echo "Extracting Maven ${DIST_VERSION}..."
    unzip -oq "${DIST_DIR}/${DIST_ARCHIVE}" -d "${DIST_DIR}"
  fi
fi

exec "${MVN_CMD}" "$@"
