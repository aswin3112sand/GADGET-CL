# Spring Boot backend reference values.
# backend/.env and backend/.env.local are auto-loaded for both the default and local profiles.
# Leave SPRING_PROFILES_ACTIVE unset for PostgreSQL / Neon.
# Uncomment the next line only when you want the local H2 profile.
# SPRING_PROFILES_ACTIVE=local
PORT=8080

# PostgreSQL / Neon database settings
# DB_URL must use jdbc:postgresql://... and not postgresql://...
# Spring Boot usually handles Neon SSL settings without extra query params.
DB_URL=jdbc:postgresql://your-neon-host.aws.neon.tech:5432/neondb
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password
JPA_SHOW_SQL=false

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION_MINUTES=1440
CHECKOUT_TOKEN_EXPIRATION_MINUTES=30
JWT_ISSUER=ecommerce-backend

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_API_BASE_URL=https://api.razorpay.com/v1
RAZORPAY_CURRENCY=INR

# Cloudinary
CLOUDINARY_CLOUD_NAME=xxxxxx
CLOUDINARY_API_KEY=xxxxxx
CLOUDINARY_API_SECRET=xxxxxx
CLOUDINARY_FOLDER=ecommerce

# Demo defaults
# Set to false when testing real Cloudinary uploads locally.
APP_DEMO_ENABLED=false
APP_DEMO_SAMPLE_IMAGE_URL=https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=1200&q=80
APP_DEMO_SAMPLE_VIDEO_URL=http://localhost:5173/hero-gadget-video.mp4

# Upload limits
UPLOAD_MAX_FILE_SIZE_MB=200
MULTIPART_MAX_FILE_SIZE=200MB
MULTIPART_MAX_REQUEST_SIZE=200MB

# Sample local admin only
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
# Set to true for one local restart if you need to overwrite the stored local admin
# password without deleting backend/.local/ecommerce-local.mv.db. Set it back to false
# after you can sign in again.
ADMIN_RESET_EXISTING_PASSWORD=false
